{
  "name": "mysa2mqtt",
  "version": "1.3.0",
  "license": "MIT",
  "private": false,
  "description": "Expose Mysa smart thermostats to home automation platforms via MQTT.",
  "keywords": [
    "mysa",
    "thermostat",
    "mqtt",
    "homeassistant",
    "home-assistant"
  ],
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "author": {
    "name": "Pascal Bourque",
    "email": "pascal@cosmos.moi"
  },
  "bugs": {
    "url": "https://github.com/bourquep/mysa2mqtt/issues"
  },
  "homepage": "https://github.com/bourquep/mysa2mqtt/tree/main/packages/mysa2mqtt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bourquep/mysa2mqtt.git",
    "directory": "packages/mysa2mqtt"
  },
  "files": [
    "README.md",
    "CHANGELOG.md",
    "LICENSE.txt",
    "dist"
  ],
  "type": "module",
  "bin": {
    "mysa2mqtt": "dist/main.js"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "browser": false,
  "scripts": {
    "dev": "tsx src/main.ts",
    "lint": "eslint --max-warnings 0 src/**/*.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsup"
  },
  "dependencies": {
    "commander": "15.0.0",
    "dotenv": "17.4.2",
    "mqtt2ha": "4.1.4",
    "mysa-js-sdk": "2.1.2",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "15.0.0"
  }
}
